# DeepSeek 翻译用
DEEPSEEK_API_KEY=

# 下载库根目录(给 X/Twitter 链接时,视频+字幕落这里的 <date>_<handle>_<id>/media/)
# 默认 ~/x-video-subtitle-library
# LIBRARY=~/x-video-subtitle-library

# 可选:whisper 模型(目录路径或大小名)。默认用内置 .models/large-v3
# WHISPER_MODEL=./.models/large-v3

# 可选:源语言(默认 en);翻译目标名(默认 Chinese)
# ASR_LANG=en
# TARGET_LANG_NAME=Chinese

# 可选:字体(fontconfig 名)。默认 中=Heiti SC / 英=Helvetica Neue
# ZH_FONT=Heiti SC
# EN_FONT=Helvetica Neue

# 可选:默认裁掉结尾秒数;也可命令行 --trim-tail
# SUBTITLE_TRIM_TAIL=0
