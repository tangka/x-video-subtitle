# DeepSeek 翻译用(可复用 x-post-cover 的同一个 key)
DEEPSEEK_API_KEY=

# 素材库根(给 X 链接时,视频+字幕落这里的 <date>_<handle>_<id>/,与 x-post-cover 同处)
# 默认 ~/wechat-vault/微信公众号/素材库
# LIBRARY=/Users/tangka/wechat-vault/微信公众号/素材库

# 可选:whisper 模型(目录路径或大小名)。默认用内置 .models/large-v3
# WHISPER_MODEL=/Users/you/Code/scripts/x-video-subtitle/.models/large-v3

# 可选:源语言(默认 en);翻译目标名(默认 Chinese)
# ASR_LANG=en
# TARGET_LANG_NAME=Chinese

# 可选:字体(fontconfig 名)。默认 中=Heiti SC / 英=Helvetica Neue
# ZH_FONT=Heiti SC
# EN_FONT=Helvetica Neue

# 可选:默认掐掉结尾秒数(防侵权);也可命令行 --trim-tail
# SUBTITLE_TRIM_TAIL=0
